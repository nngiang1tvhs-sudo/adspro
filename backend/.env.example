# Server Configuration
PORT=5000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/adspro
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adspro
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Authentication
JWT_SECRET=adspro_super_secret_key_change_this_in_production_2026
JWT_EXPIRES_IN=7d

# Admin Account (auto-created on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@adspro.local

# Email Service (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=AdsPro <noreply@yourdomain.com>
EMAIL_TO=admin@yourdomain.com

# Encryption key for storing API tokens (32 chars)
ENCRYPTION_KEY=adspro_token_encryption_key_2026

# Cron Schedule (default: 7:00 AM Vietnam time)
DAILY_REPORT_CRON=0 7 * * *
SYNC_CRON=*/15 * * * *
RULES_CRON=*/5 * * * *
TIMEZONE=Asia/Ho_Chi_Minh

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
